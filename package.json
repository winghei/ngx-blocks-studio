{
  "name": "ngx-blocks-studio",
  "version": "0.1.0",
  "scripts": {
    "ng": "ng",
    "master-css:compile": "node scripts/compile-master-css.mjs",
    "master-css:watch": "node scripts/compile-master-css.mjs --watch",
    "start": "npm run master-css:compile && ng serve demo",
    "build": "ng build blocks-studio",
    "build:lib": "ng build blocks-studio",
    "build:demo": "npm run master-css:compile && ng build demo",
    "watch": "ng build blocks-studio --watch --configuration development",
    "pack:lib": "ng build blocks-studio && cd dist/blocks-studio && npm pack",
    "test": "ng test",
    "test:block-directives": "vitest run --config tests/block-directives/vitest.config.ts",
    "publish:lib": "./scripts/publish-lib.sh",
    "publish:lib:dry": "./scripts/publish-lib.sh --dry-run"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@master/css": "^2.0.0-rc.85",
    "@master/css-preset": "^2.0.0-rc.85",
    "@master/css-project": "^2.0.0-rc.85",
    "@master/css-runtime": "^2.0.0-rc.85",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.2",
    "@angular/cli": "^21.1.2",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@types/node": "^25.5.2",
    "jsdom": "^27.1.0",
    "ng-packagr": "^21.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
